<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:compilerservices="using:System.Runtime.CompilerServices"
             x:Class="ColorPickerApp.App"
             xmlns:local="using:ColorPickerApp"
             xmlns:vm="using:ColorPickerApp.ViewModels"
             RequestedThemeVariant="Default"
             x:DataType="vm:MainWindowViewModel">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    
    <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/avalonia-logo.ico"
                ToolTipText="Color Picker Pro"
                Command="{Binding ShowWindowCommand}">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Открыть" Command="{Binding ShowWindowCommand}" Gesture="{Binding OpenWindowKeyGesture}">
            </NativeMenuItem>
            <NativeMenuItem Header="Пипетка" Command="{Binding ShowEyedropper}" Gesture="{Binding PickerKeyGesture}"/>
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Выход" Command="{Binding QuitCommand}"/>
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
    </Application.Styles>
</Application>