        </StreamGeometry>	
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button, ToggleButton">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="TextBox">
		<Setter Property="Background" Value="#2E2E2E"/>
		<Setter Property="Foreground" Value="#BBBBBB"/>
		<Setter Property="BorderBrush" Value="#4A4A4A"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Padding" Value="5"/>
	</Style>
	<Style Selector="TextBox:focus">
		<Setter Property="Background" Value="#2E2E2E"/>
		<Setter Property="Foreground" Value="#BBBBBB"/>
		<Setter Property="BorderBrush" Value="#4A4A4A"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Padding" Value="5"/>
	</Style>
	<Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
		<Setter Property="Background" Value="#404040" />
		<Setter Property="BorderBrush" Value="#6A6A6A" />
	</Style>
	<Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
		<Setter Property="Background" Value="#2E2E2E" />
		<Setter Property="BorderBrush" Value="#6A6A6A" />
	</Style>
	<Style Selector="TextBox:disabled">
		<Setter Property="Foreground" Value="#BBBBBB"/>
	</Style>
	<Style Selector="TextBox:disabled /template/ Border#PART_BorderElement">
		<Setter Property="Background" Value="#515151"/>
	</Style>
    <Style Selector="NumericUpDown">
		<Setter Property="Background" Value="#2E2E2E"/>
		<Setter Property="Foreground" Value="#BBBBBB"/>
		<Setter Property="BorderBrush" Value="#4A4A4A"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Padding" Value="5"/>
	</Style>

    <Style Selector="NumericUpDown /template/ ButtonSpinner#PART_Spinner:right /template/ RepeatButton#PART_DecreaseButton /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="CornerRadius" Value="0,3,3,0"/>
	</Style>


        <Style Selector="ComboBox">
		<Setter Property="Background" Value="#2E2E2E"/>
		<Setter Property="Foreground" Value="#BBBBBB"/>
		<Setter Property="BorderBrush" Value="#4A4A4A"/>
	</Style>

	<Style Selector="ComboBox:pointerover /template/ Border#Background">
		<Setter Property="Background" Value="#404040" />
		<Setter Property="BorderBrush" Value="#6A6A6A" />
	</Style>

	<Style Selector="ComboBoxItem">
		<Setter Property="Foreground" Value="#BBBBBB" />
	</Style>

	<Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
		<Setter Property="Background" Value="#404040" />
		<Setter Property="Foreground" Value="#BBBBBB" />
		<Setter Property="BorderBrush" Value="#4A4A4A" />
	</Style>

	<Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
		<Setter Property="Foreground" Value="LightGray" />
		<Setter Property="Background" Value="#404040" />
		<Setter Property="BorderBrush" Value="#6A6A6A" />
	</Style>
        <Style Selector="Button.eyeDropper">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.previewCopy">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style Selector="Button.previewCopy:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="#77FFFFFF" />
        </Style>
        <Style Selector="Button.previewCopy:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="#FFFFFF" />
        </Style>

        <Style Selector="Button.swatcherButton">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.swatcherButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="#77FFFFFF" />
        </Style>
        <Style Selector="Button.swatcherButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BorderBrush" Value="#FFFFFF" />
        </Style>

        <Style Selector="Border.panel">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderBrush" Value="#30FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="ToggleButton">
            <Setter Property="CornerRadius" Value="0, 0, 10, 10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#30FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ToggleButton:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ToggleButton.lattice">
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="1, 0, 1, 0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ToggleButton.lattice:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ToggleButton.lattice:unchecked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="BorderBrush" Value="#00FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ToggleButton.lattice:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="BorderBrush" Value="#77FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ToggleButton.lattice:pressed /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="BorderBrush" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

    </Window.Styles>

    <Panel>
        <DockPanel Margin="18" LastChildFill="True">
            <Border Classes="panel" DockPanel.Dock="Bottom" Margin="0,14,0,0">
                <Grid ColumnDefinitions="342,Auto,Auto,Auto,*" ColumnSpacing="8" MinHeight="64">
                    <Button Grid.Column="0"
                            Classes="previewCopy"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Click="OnCopyClick">
                        <Border CornerRadius="12" ClipToBounds="True">
                            <Grid>
                                <controls:CheckerboardControl CellSize="12" />
                                <Border Background="{Binding SelectedBrush}" CornerRadius="12" />
                                <Label x:Name="lableContent" 
                                       Content="Скопированно" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       FontSize="25" 
                                       FontWeight="500"
                                       IsVisible="False"
                                       Foreground="{Binding SelectedColor, Converter={StaticResource ColorToBrushConverter}}"/>
                            </Grid>
                        </Border>
                    </Button>
                    <ComboBox Grid.Column="1"
                              Name="CopyFormatBox"
                              Width="130"
                              VerticalAlignment="Center"
                              SelectedIndex="{Binding CopyFormatIndex}"
                              SelectionChanged="OnCopyFormatChanged">
                        <ComboBoxItem Content="rgb" />
                        <ComboBoxItem Content="hsv" />
                        <ComboBoxItem Content="normal" />
                        <ComboBoxItem Content="hex" />
                    </ComboBox>
                    <ToggleSwitch Grid.Column="2"
                                  IsChecked="{Binding CopyWithAlpha}"
                                  VerticalAlignment="Center"
                                  OnContent=""
                                  OffContent=""
                                  Content="С alpha" />
                    <Panel Grid.Column="3">
                        <ToggleButton 
                            Name="latticeToggleButton"
                            Content="ƒ" 
                            Classes="lattice"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Width="23"
                            Height="32"
                            FontSize="25" 
                            FontWeight="Bold"
                            IsCheckedChanged="latticeToggleButton_Checked"/>
                    </Panel>
                    <TextBox Grid.Column="4"
                             MaxWidth="290"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Stretch"
                             IsReadOnly="True"
                             Name="CopyValueBox" />
                </Grid>
            </Border>

            <Grid ColumnDefinitions="412,1.4*" ColumnSpacing="16">
                <Border Classes="panel" Grid.Column="0">
                    <DockPanel LastChildFill="True">
                        <Grid Margin="-12" DockPanel.Dock="Top" ColumnDefinitions="auto,*,auto">
                            <Button Content="1" Grid.Column="0" Click="ButtonBackColorMode_OnClick">
                                <Button.Content>
						            <PathIcon Data="{StaticResource arrow-left-icon}" Foreground="LightGray" Width="14" Height="14"/>		
                                </Button.Content>
                            </Button>
                            <Label Name="ColorModeLabel" Content="Моно" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="1"/>
                            <Button Content="2" Grid.Column="2" Click="ButtonNextColorMode_OnClick">
                                <Button.Content>		
						            <PathIcon Data="{StaticResource arrow-right-icon}" Foreground="LightGray" Width="14" Height="14"/>	
                                </Button.Content>
                            </Button>
                        </Grid>
                        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="320,Auto" ColumnSpacing="10" Margin="0,0,0,0">
                            <StackPanel>
                                <WrapPanel Grid.Column="0" Name="SwatchesPanel" />
                                <WrapPanel Grid.Column="0" ItemsAlignment="Center" Width="320" Height="25">
						            <ItemsControl ItemsSource="{Binding AdditionalColors}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>		
                                </WrapPanel>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="eyeDropper"
                                    VerticalAlignment="Top"
                                    Click="OnEyedropperClick"
                                    HorizontalAlignment="Left"
                                    Margin="-3, 0, 0, 0"
                                    Width="56" Height="56">
                                <Image Source="/Assets/color-picker.png" Stretch="Uniform" Width="30" Height="30" />
                            </Button>
                        </Grid>
                        <Grid ColumnDefinitions="Auto,24" ColumnSpacing="10">
                            <controls:ColorWheelSvControl Name="Wheel"
                                                          Width="320"
                                                          Height="320"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Hue="{Binding Hue, Mode=TwoWay}"
                                                          Saturation="{Binding Saturation, Mode=TwoWay}"
                                                          Value="{Binding Value, Mode=TwoWay}" />
                            <controls:AlphaSliderControl Grid.Column="1"
                                                         Height="320"
                                                         Width="26"
                                                         HorizontalAlignment="Stretch"
                                                         VerticalAlignment="Center"
                                                         BaseColor="{Binding OpaqueColor}"
                                                         Alpha="{Binding Alpha, Mode=TwoWay}" />
                        </Grid>
                    </DockPanel>
                </Border>

                <Border Classes="panel" Grid.Column="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="14">
                            <TextBlock Text="RGB" FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="24,*,24,*" RowDefinitions="Auto,Auto" RowSpacing="2">
                                <TextBlock Text="R" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="255" FormatString="F0" Value="{Binding R, Mode=TwoWay}" />
                                <TextBlock Grid.Column="2" Text="A" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="3" Minimum="0" Maximum="1" Increment="0.01" FormatString="F2" Value="{Binding Alpha, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" Text="G" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" FormatString="F0" Value="{Binding G, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="B" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Row="1" Grid.Column="3" Minimum="0" Maximum="255" FormatString="F0" Value="{Binding B, Mode=TwoWay}" />
                            </Grid>

                            <TextBlock Text="HSV" FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="24,*,24,*" RowDefinitions="Auto,Auto" RowSpacing="2">
                                <TextBlock Text="H" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="360" Increment="1" FormatString="F2" Value="{Binding Hue, Mode=TwoWay}" />
                                <TextBlock Grid.Column="2" Text="A" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="3" Minimum="0" Maximum="1" Increment="0.01" FormatString="F2" Value="{Binding Alpha, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" Text="S" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="1" Increment="0.01" FormatString="F2" Value="{Binding Saturation, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="V" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Row="1" Grid.Column="3" Minimum="0" Maximum="1" Increment="0.01" FormatString="F2" Value="{Binding Value, Mode=TwoWay}" />
                            </Grid>

                            <TextBlock Text="Normal (0..1)" FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="24,*,24,*" RowDefinitions="Auto,Auto" RowSpacing="2">
                                <TextBlock Text="R" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" Increment="0.01" FormatString="F2" Value="{Binding NormalR, Mode=TwoWay}" />
                                <TextBlock Grid.Column="2" Text="A" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Column="3" Minimum="0" Maximum="1" Increment="0.01" FormatString="F2" Value="{Binding Alpha, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" Text="G" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="1" Increment="0.01" FormatString="F2" Value="{Binding NormalG, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="B" Margin="12,0,0,0" VerticalAlignment="Center" />
                                <NumericUpDown Grid.Row="1" Grid.Column="3" Minimum="0" Maximum="1" Increment="0.01" FormatString="F2" Value="{Binding NormalB, Mode=TwoWay}" />
                            </Grid>

                            <TextBlock Text="Hex" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Hex, Mode=TwoWay}" Watermark="#rrggbb" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </DockPanel>
        <SplitView x:Name="SplitViewControl" 
            DisplayMode="CompactInline"
			HorizontalAlignment="Left"
            OpenPaneLength="{Binding #main.Bounds.Width}"
			CompactPaneLength="18"
            PaneBackground="Black"
            CornerRadius="0, 10, 10, 0"
            Margin="-20, 0, 0, 0"
			IsPaneOpen="{Binding #ToggleButtonHide.IsChecked}">
			<SplitView.Pane>
				<Grid ColumnDefinitions="*,auto" Background="Transparent">
                    <Panel Grid.Column="0">
						<Border Classes="panel" Margin="20, 20, 40, 20">
							<v:SettingsView  />
                        </Border>
                    </Panel>
                    
					<ToggleButton 
                    Grid.Column="1" 
                    x:Name="ToggleButtonHide" 
                    Margin="-18, 0, 0, 0" 
                    Padding="0"
                    VerticalAlignment="Stretch" 
                    HorizontalAlignment="Right" 
                    Width="18" 
                    Background="#1a1a1a"
                    BorderBrush="#30FFFFFF"
                    BorderThickness="1"
                    HorizontalContentAlignment="Center" 
                    VerticalContentAlignment="Center"
                    CornerRadius="0, 10, 10, 0">
						<Path Data="M0,0 L10,10 L0,20 Z" Fill="LightGray">
							<Path.RenderTransform>
								<RotateTransform Angle="{Binding #ToggleButtonHide.IsChecked, Converter={StaticResource BoolToAngleConverter}}"/>
							</Path.RenderTransform>
						</Path>
                        <ToggleButton.Styles>
							<Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
								<Setter Property="CornerRadius" Value="10, 0, 0, 10" />
                                <Setter Property="Background" Value="#1a1a1a" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                            </Style>
                            <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="#303030" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                                
                            </Style>
                        </ToggleButton.Styles>
					</ToggleButton>
                    
				</Grid>
			</SplitView.Pane>
		</SplitView>
    </Panel>
</Window>
