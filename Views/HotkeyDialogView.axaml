<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:reactiveUi="clr-namespace:ReactiveUI;assembly=ReactiveUI"
        xmlns:vm="clr-namespace:ColorPickerApp.ViewModels"
        x:Class="ColorPickerApp.Views.HotkeyDialogView"
        x:DataType="vm:HotkeyDialogViewModel"
        Title="Назначить горячую клавишу"
        Width="400" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e"
        RequestedThemeVariant="Dark">

    <Design.DataContext>
        <vm:HotkeyDialogViewModel/>
    </Design.DataContext>

    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Нажмите желаемую комбинацию клавиш" 
                   HorizontalAlignment="Center"
                   FontWeight="Bold"/>
        <Border 
                Background="#484848"
                CornerRadius="5"
                Padding="10"
                Margin="0,10">
            <TextBlock Text="{Binding CurrentHotkey, FallbackValue='[ожидание нажатия]'}"
                       FontSize="18"
                       FontFamily="Courier New"
                       HorizontalAlignment="Center"
                       FontWeight="Bold"/>
        </Border>
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <Button Content="Подтвердить" Command="{Binding ConfirmCommand}" Width="120" HorizontalContentAlignment="Center"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" Width="120" HorizontalContentAlignment="Center"/>
        </StackPanel>
        <TextBlock Text="(Для отмены можно просто закрыть окно)"
                   FontSize="10"
                   Foreground="Gray"
                   HorizontalAlignment="Center"/>
    </StackPanel>
</Window>